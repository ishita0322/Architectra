# Application
APP_NAME=AI System Architect
ENVIRONMENT=development

# Database
#   Local dev (zero setup):   sqlite:///./architect.db
#   Docker compose / prod:    postgresql+psycopg2://postgres:postgres@db:5432/architect
DATABASE_URL=sqlite:///./architect.db

# Auth (Milestone 1+)
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# AI provider (Milestone 5+)
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:8b

# CORS
CORS_ORIGINS=http://localhost:5173
